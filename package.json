{
  "name": "taskpilot",
  "displayName": "TaskPilot",
  "description": "A sidebar dashboard for AI-assisted coding sessions",
  "version": "0.1.0",
  "publisher": "taskpilot",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gogogoober/on-task.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "workspaceContains:.taskpilot",
    "onCommand:taskpilot.init"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "taskpilot-sidebar",
          "title": "TaskPilot",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "taskpilot-sidebar": [
        {
          "type": "webview",
          "id": "taskpilot.dashboard",
          "name": "Dashboard"
        }
      ]
    },
    "commands": [
      { "command": "taskpilot.init", "title": "TaskPilot: Initialize" },
      { "command": "taskpilot.refresh", "title": "TaskPilot: Refresh" }
    ]
  },
  "scripts": {
    "compile": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "smol-toml": "^1.3.0"
  }
}
